# ==========================================
# Configuración del Sistema Inteligente de Radar
# ==========================================

# -- Opciones Generales --
# Distancia en metros entre las dos líneas virtuales
DISTANCIA_REFERENCIA_METROS=5.0

# -- Configuración de DroidCam / Cámara Móvil --
# IP de tu teléfono con DroidCam
IP_IPHONE=192.168.9.129
# Puerto de DroidCam (4747 por defecto)
PUERTO=4747

# -- Configuración de Correo Electrónico (SMTP) --
# Servidor SMTP (Office 365, Gmail, etc.)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587

# Credenciales del correo de envío
SMTP_USER=tu_correo@ejemplo.com
SMTP_PASSWORD=tu_contrasena_aqui
SMTP_FROM=tu_correo@ejemplo.com

# Correo de destino para notificaciones de infracciones
ENVIO_INFRACCIONES_A=destino@ejemplo.com
